# Copy this file to .env and customise as needed.
# The server will load it automatically via python-dotenv.

# ── ENA API Base URLs ────────────────────────────────────────────
# Override for internal mirrors or staging environments.
ENA_PORTAL_BASE=https://www.ebi.ac.uk/ena/portal/api
ENA_BROWSER_BASE=https://www.ebi.ac.uk/ena/browser/api

# ── HTTP Client ──────────────────────────────────────────────────
# Timeout in seconds for each HTTP request.
ENA_TIMEOUT=30

# Number of retry attempts on transient errors (with exponential back-off).
ENA_MAX_RETRIES=3

# ── Rate Limiting ────────────────────────────────────────────────
# Sustained requests per second (token-bucket rate).
# Keep this at 5 or below to be polite to ENA.
ENA_RATE_LIMIT=5

# ── Response Cache ───────────────────────────────────────────────
# Cache TTL in seconds (0 = disabled).
ENA_CACHE_TTL=300

# Maximum number of cached responses.
ENA_CACHE_SIZE=512

# ── Logging ──────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
